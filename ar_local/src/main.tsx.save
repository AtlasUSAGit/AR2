import {StrictMode} from 'react';
import {createRoot} from 'react-dom/client';
import App from './App.tsx';
import './index.css';
import { AppProvider } from './AppContext';
import { Amplify } from 'aws-amplify';

try {
  Amplify.configure({
    API: {
      GraphQL: {
        endpoint: 'https://placeholder-api.appsync-api.us-east-1.amazonaws.com/graphql',
        region: 'us-east-1',
        defaultAuthMode: 'apiKey',
        apiKey: 'da2-placeholderapi'
      }
    }
  });
} catch (e) {
  console.warn('Amplify configuration skipped/failed:', e);
}

createRoot(document.getElementById('root')!).render(
  <StrictMode>
    <AppProvider>
      <App />
    </AppProvider>
  </StrictMode>,
);

